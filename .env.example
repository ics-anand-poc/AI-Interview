NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNmcXBkanB2emdrdnBpcGFpbnpwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg2ODQ1NTksImV4cCI6MjA5NDI2MDU1OX0.fGVkQoBwfzTtZjBs-RXXwIbYWj1EKPuTTfR-XJuzz7Y
# Service-role key bypasses Row Level Security — used server-side by src/lib/db.ts.
# Keep this secret; never expose it with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=
UPLOAD_SECRET_KEY=
ENCRYPTION_KEY=
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin login password — defaults to the INSECURE value "12345" if left unset
# (see src/app/api/admin/auth/login/route.ts). Always set this explicitly.
ADMIN_PASSWORD=

# --- AI Provider Selection ---
# Which LLM backs resume scoring, interview question generation, and answer evaluation.
# Supported values: gemini | ollama | copilot | groq   (defaults to "gemini" if unset)
# Local heuristic/mock fallbacks throughout the app are unchanged either way.
AI_PROVIDER=gemini

# Gemini (Google Generative AI) — used when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (fast, low-cost hosted inference for open models) — used when AI_PROVIDER=groq
# Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_BASE_URL=https://api.groq.com/openai/v1

# Ollama (local/self-hosted models) — used when AI_PROVIDER=ollama
# Requires a running Ollama server: https://github.com/ollama/ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# GitHub Copilot (chat completions) — used when AI_PROVIDER=copilot
# Requires a valid Copilot chat token; see src/lib/ai-providers/copilot-provider.ts for details.
COPILOT_API_KEY=
COPILOT_API_BASE_URL=https://api.githubcopilot.com
COPILOT_MODEL=gpt-4o
COPILOT_INTEGRATION_ID=vscode-chat

# In-memory response cache for LLM calls (reduces duplicate/redundant API calls).
# See src/lib/ai-providers/cache.ts
AI_CACHE_ENABLED=true
AI_CACHE_TTL_MS=600000

# JD-to-BR structured extraction (src/lib/jd-to-br) uses the configured AI provider by
# default to extract fields directly from each JD document (grounded strictly to that
# document's actual text — never inferring/fabricating), falling back automatically to
# a deterministic regex/keyword parser only if every LLM call fails. Set this to "true"
# to skip the LLM entirely and always use the deterministic parser (e.g. a fully
# offline/zero-cost deployment).
JD_EXTRACTION_FORCE_LOCAL=false

# SMTP credentials for real email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=aryan.collageid@gmail.com
SMTP_PASS=
SMTP_FROM="ResumePro Automated HR" <aryan.collageid@gmail.com>